{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/artikel/:slug",
      "destination": "/api/index.ts?slug=:slug"
    },
    {
      "source": "/((?!api|artikel).*)",
      "destination": "/index.html"
    }
  ]
}
