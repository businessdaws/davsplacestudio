rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow connectivity test
    match /test/connection {
      allow read: if true;
    }

    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Check if user is an admin by looking up the profiles collection or checking whitelisted emails first
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && (
          request.auth.token.email.matches('(?i)^(davsplacestudio|businessdaws|buainessdaws|fajarmuniri)@gmail\\.com$') ||
          request.auth.token.email.matches('(?i)^admin@davs\\.studio$')
        )) ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---

    function isValidProfile(data) {
      return data.keys().hasAll(['id']) &&
             data.id is string && data.id == request.auth.uid &&
             (data.get('full_name', '') is string) &&
             (data.get('avatar_url', '') is string) &&
             (data.get('role', 'user') in ['user', 'admin']);
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug', 'type']) &&
             data.name is string && data.name.size() > 0 &&
             data.slug is string && data.slug.size() > 0 &&
             data.type in ['artikel', 'layanan', 'portofolio', 'event'];
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'slug', 'content']) &&
             data.title is string && data.title.size() > 0 &&
             data.slug is string && data.slug.size() > 0 &&
             data.content is string && data.content.size() > 0;
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 &&
             data.slug is string && data.slug.size() > 0;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title']) &&
             data.title is string && data.title.size() > 0;
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['title']) &&
             data.title is string && data.title.size() > 0;
    }

    function isValidUsefulLink(data) {
      return data.keys().hasAll(['title', 'url']) &&
             data.title is string && data.title.size() > 0 &&
             data.url is string && data.url.size() > 0;
    }

    function isValidClientLogo(data) {
      return data.keys().hasAll(['company_name', 'logo_url']) &&
             data.company_name is string && data.company_name.size() > 0 &&
             data.logo_url is string && data.logo_url.size() > 0;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'message']) &&
             data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.message is string && data.message.size() > 0;
    }

    function isValidSiteSettings(data) {
      return true; // Simple allow-all for site settings structure if admin
    }

    function isValidCommunity(data) {
      return data.keys().hasAll(['name', 'url']) &&
             data.name is string && data.name.size() > 0 &&
             data.url is string && data.url.size() > 0;
    }

    function isValidSavedContent(data) {
      return data.keys().hasAll(['user_id', 'topic', 'headline', 'caption']) &&
             data.user_id == request.auth.uid &&
             data.topic is string && data.topic.size() > 0 &&
             data.headline is string && data.headline.size() > 0 &&
             data.caption is string && data.caption.size() > 0;
    }

    function isValidWatermarkTemplate(data) {
      return data.keys().hasAll(['id', 'name', 'uid']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.uid == request.auth.uid;
    }

    function isValidProspect(data) {
      return data.keys().hasAll(['prospect_name', 'category', 'pain_points', 'opportunity_rate', 'action_plan']) &&
             data.prospect_name is string && data.prospect_name.size() > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.pain_points is string && data.pain_points.size() > 0 &&
             data.opportunity_rate is string && data.opportunity_rate.size() > 0 &&
             data.action_plan is string && data.action_plan.size() > 0 &&
             (data.get('channel_link', '') is string);
    }

    function isValidBillingDoc(data) {
      return data.keys().hasAll(['type', 'doc_number', 'client_name', 'project_name', 'total', 'status']) &&
             data.type is string &&
             data.doc_number is string &&
             data.client_name is string &&
             data.project_name is string &&
             data.total is number &&
             data.status is string;
    }

    // --- COLLECTION RULES ---

    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isAdmin() || (
        isOwner(userId) && 
        isValidProfile(incoming()) && 
        incoming().role == existing().role &&
        (
          (incoming().get('is_premium', false) == existing().get('is_premium', false)) ||
          (
            incoming().get('is_premium', false) == true && 
            existing().get('is_premium', false) == false &&
            incoming().get('premium_code', '') != '' &&
            exists(/databases/$(database)/documents/activation_codes/$(incoming().premium_code)) &&
            get(/databases/$(database)/documents/activation_codes/$(incoming().premium_code)).data.is_used == false
          )
        )
      );
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidArticle(incoming());
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidService(incoming());
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    match /portfolios/{portfolioId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPortfolio(incoming());
      allow delete: if isAdmin();
    }

    match /useful_links/{linkId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidUsefulLink(incoming());
      allow delete: if isAdmin();
    }

    match /client_logos/{logoId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidClientLogo(incoming());
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if isValidLead(incoming());
      allow read, delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSiteSettings(incoming());
      allow delete: if isAdmin();
    }

    match /communities/{communityId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCommunity(incoming());
      allow delete: if isAdmin();
    }

    match /saved_contents/{contentId} {
      allow list: if isSignedIn(); // Queries must filter by user_id
      allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidSavedContent(incoming());
      allow update: if isSignedIn() && isOwner(existing().user_id) && isValidSavedContent(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().user_id) || isAdmin());
    }

    match /activation_codes/{codeId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        incoming().is_used == true &&
        existing().is_used == false &&
        incoming().used_by == request.auth.uid &&
        incoming().used_by_email == request.auth.token.email
      );
    }

    match /watermark_templates/{templateId} {
      allow list: if isSignedIn(); // Queries must filter by uid
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidWatermarkTemplate(incoming());
      allow update: if isSignedIn() && isOwner(existing().uid) && isValidWatermarkTemplate(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().uid) || isAdmin());
    }

    match /prospects/{prospectId} {
      allow read, delete: if isAdmin();
      allow create, update: if isAdmin() && isValidProspect(incoming());
    }

    match /billing_docs/{docId} {
      allow read, delete: if isAdmin();
      allow create, update: if isAdmin() && isValidBillingDoc(incoming());
    }
  }
}
